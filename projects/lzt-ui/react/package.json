{
  "name": "@open-lzt/ui",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./lzt-ui.css": "./lzt-ui.css"
  },
  "files": [
    "dist",
    "lzt-ui.css"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.3.0"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-css.mjs",
    "typecheck": "tsc --noEmit"
  }
}
