# open-lzt unified stand config. Copy to `.env` and fill secrets, then run ./install.sh.
# install.sh renders per-service env files (deploy/env/*.env) from these canonical values, so the
# LZT_ prefix used by BOTH the eventus engine and flow's embedded engine never collides — each
# systemd service gets its own EnvironmentFile.

# ---- market mode --------------------------------------------------------------------------------
# testnet = every service hits the in-stand mock (no real money/tokens); prod = real lzt.market.
MARKET_MODE=testnet

# ---- infra (docker-compose.yml) ----------------------------------------------------------------
POSTGRES_USER=lzt
POSTGRES_PASSWORD=
POSTGRES_DB=lztflow
POSTGRES_PORT=55432
REDIS_PORT=56379
# Redis holds the money-idempotency guards (idem:*) and the arq job queue, so anything that reaches
# it can make every paid node duplicate its effect, or push a job and run code in the worker.
# install.sh generates this next to POSTGRES_PASSWORD; docker compose refuses to start without it.
REDIS_PASSWORD=

# ---- service ports (all bound to 127.0.0.1) ----------------------------------------------------
TESTNET_PORT=8765
EVENTUS_PORT=27543
FLOW_PORT=8000
MCP_PORT=8770

# ---- secrets (generate with the commands in comments) ------------------------------------------
# Fernet key: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
FLOW_MASTER_KEY=
EVENTUS_TOKEN_ENC_KEY=
# openssl rand -hex 32
FLOW_API_KEY=
EVENTUS_ADMIN_API_KEY=

# ---- lzt.market tokens for the eventus engine (JSON array). Empty is fine in testnet mode. ------
# WRAP IT IN SINGLE QUOTES: this file is read with `source`, which would otherwise strip the inner
# double quotes and hand the engine invalid JSON.
# e.g. EVENTUS_TOKENS='["token-a","token-b"]'
EVENTUS_TOKENS=[]

# ---- single-tenant id ---------------------------------------------------------------------------
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# ---- outbound requests (lzt-flow egress fence) --------------------------------------------------
# The COMPLETE list of hosts a flow's request node may reach. Empty = reach nothing, which is the
# safe default: a community module can name a URL, so an unconfigured fence must fail closed rather
# than open this host's private network. Comma-separated, exact names (no wildcards, no suffixes).
LZT_FLOW_EGRESS_ALLOWED_HOSTS=api.telegram.org

# ---- telegram admin bot (optional) --------------------------------------------------------------
# Off unless BOT_ENABLED=1 AND both a token and an admin list are set — a bot with a token but no
# admins would answer everyone. Set these with `sudo bash scripts/bot-bootstrap.sh --token <t>
# --admins <ids>`, which is re-runnable and will not wipe an existing admin list.
BOT_ENABLED=0
# from @BotFather
BOT_TOKEN=
# your numeric telegram id(s) from @userinfobot — comma-separated, e.g. 111,222
BOT_ADMIN_IDS=

# ---- public access / TLS (install.sh prompts for these if blank & interactive) ------------------
# DOMAIN set  -> nginx + Let's Encrypt cert (needs DNS pointed here + ports 80/443 open).
# DOMAIN blank + TLS_MODE=selfsigned -> nginx + self-signed cert on this host's IP.
# TLS_MODE=none (default) -> loopback only, no public exposure.
DOMAIN=
TLS_MODE=none
LETSENCRYPT_EMAIL=
